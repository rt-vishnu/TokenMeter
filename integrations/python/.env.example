# Copy this file to .env and fill in your keys:
#   copy .env.example .env
#
# Get Gemini key: https://aistudio.google.com/apikey
# PromptPenny values: Integration screen in the app (endpoint + API key)

GEMINI_API_KEY=your-gemini-api-key-here
PROMPT_PENNY_URL=http://192.168.0.108:8765
PROMPT_PENNY_API_KEY=your-promptpenny-api-key-here

# Current models (1.5-flash and 2.0-flash are retired — use 2.5+)
GEMINI_MODEL=gemini-2.5-flash-lite
PROMPT_PENNY_MODEL=gemini-2.5-flash-lite
# PROMPT_PENNY_SOURCE=gemini-api-test
