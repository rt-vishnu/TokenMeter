# Copy this file to .env and fill in your keys:
#   copy .env.example .env
#
# Get Gemini key: https://aistudio.google.com/apikey
# TokenMeter values: Integration screen in the app (endpoint + API key)

GEMINI_API_KEY=your-gemini-api-key-here
TOKEN_METER_URL=http://192.168.0.108:8765
TOKEN_METER_API_KEY=your-tokenmeter-api-key-here

# Current models (1.5-flash and 2.0-flash are retired — use 2.5+)
GEMINI_MODEL=gemini-2.5-flash-lite
TOKEN_METER_MODEL=gemini-2.5-flash-lite
# TOKEN_METER_SOURCE=gemini-api-test
