{
  "name": "promptpenny-vscode",
  "displayName": "PromptPenny",
  "description": "Automatically track AI token usage and costs in PromptPenny",
  "version": "1.0.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "PromptPenny",
      "properties": {
        "promptpenny.url": {
          "type": "string",
          "default": "http://127.0.0.1:8765",
          "description": "PromptPenny API server URL (from Integration screen)"
        },
        "promptpenny.apiKey": {
          "type": "string",
          "default": "",
          "description": "PromptPenny API key (from Integration screen)"
        },
        "promptpenny.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic token tracking"
        },
        "promptpenny.source": {
          "type": "string",
          "default": "vscode",
          "description": "Source label shown in PromptPenny (e.g. vscode, copilot)"
        }
      }
    },
    "commands": [
      {
        "command": "promptpenny.showStatus",
        "title": "PromptPenny: Show Status"
      },
      {
        "command": "promptpenny.testConnection",
        "title": "PromptPenny: Test Connection"
      },
      {
        "command": "promptpenny.openSettings",
        "title": "PromptPenny: Open Settings"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
