{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PromptPenny: Report Usage",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/integrations/python/report_usage.py",
        "--model", "${input:promptPennyModel}",
        "--input", "${input:promptPennyInput}",
        "--output", "${input:promptPennyOutput}",
        "--source", "vscode"
      ],
      "options": {
        "env": {
          "PROMPT_PENNY_URL": "${input:promptPennyUrl}",
          "PROMPT_PENNY_API_KEY": "${input:promptPennyApiKey}"
        }
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "promptPennyUrl",
      "type": "promptString",
      "description": "PromptPenny API URL",
      "default": "http://192.168.1.42:8765"
    },
    {
      "id": "promptPennyApiKey",
      "type": "promptString",
      "description": "PromptPenny API key"
    },
    {
      "id": "promptPennyModel",
      "type": "promptString",
      "description": "Model ID",
      "default": "gpt-4o"
    },
    {
      "id": "promptPennyInput",
      "type": "promptString",
      "description": "Input tokens",
      "default": "0"
    },
    {
      "id": "promptPennyOutput",
      "type": "promptString",
      "description": "Output tokens",
      "default": "0"
    }
  ]
}
